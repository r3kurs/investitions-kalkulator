<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/blue_darker"
        app:elevation="4dp">

        <!--
            Toolbar: App-Titel links, "KI-generiert" rechtsbündig klein.
            Kein extra contentInsetStart, um Platz zu sparen.
        -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/tvAppTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:text="@string/app_name"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                android:text="@string/app_name_subtitle"
                android:textColor="#99FFFFFF"
                android:textSize="11sp" />

        </RelativeLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/card_margin"
            android:paddingEnd="@dimen/card_margin"
            android:paddingTop="12dp">

            <!-- ===== CARD 1: Allgemeine Vorgaben ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardVorgaben"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/card_margin"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="2dp"
                app:strokeColor="@color/card_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <!-- Header-Zeile: Titel links, Hilfe-Button rechts -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_alignParentStart="true"
                            android:text="@string/header_vorgaben"
                            android:textSize="@dimen/section_header_size"
                            android:textColor="@color/blue_primary"
                            android:textStyle="bold"
                            android:letterSpacing="0.08"
                            android:textAllCaps="true" />

                        <!-- Hilfe-Button: kleiner runder Knopf oben rechts -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnHilfe"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="@string/btn_hilfe"
                            android:textSize="14sp"
                            android:textColor="@color/white"
                            android:padding="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:insetLeft="0dp"
                            android:insetRight="0dp"
                            app:cornerRadius="16dp"
                            app:backgroundTint="@color/blue_primary"
                            style="@style/Widget.Material3.Button" />

                    </RelativeLayout>

                    <!-- Investierbares Vermögen (volle Breite) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilVermoegen"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/label_vermoegen"
                        android:layout_marginBottom="@dimen/field_spacing"
                        app:endIconMode="clear_text">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etVermoegen"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:digits="0123456789."
                            android:hint="@string/hint_vermoegen"
                            android:imeOptions="actionNext"
                            android:textColor="@color/on_surface" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!--
                        Dreispaltige Zeile:
                          Spalte 1 (weight 0.8): Risiko (%) – Dezimalfeld, max 4 Zeichen (99,5 → 4)
                          Spalte 2 (weight 1.0): Risikokapital live-Anzeige
                          Spalte 3 (weight 1.2): Gebühren Eingabefeld (max 99,99)
                    -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/field_spacing">

                        <!-- Risiko (%) — jetzt Dezimalfeld mit Komma -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilRisiko"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.8"
                            android:layout_marginEnd="4dp"
                            android:hint="@string/label_risiko"
                            app:endIconMode="none">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etRisiko"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:digits="0123456789,."
                                android:maxLength="4"
                                android:hint="@string/hint_risiko"
                                android:imeOptions="actionNext"
                                android:textColor="@color/on_surface" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Risikokapital live-Anzeige -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="6dp"
                            android:paddingEnd="4dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_risikokapital"
                                android:textSize="11sp"
                                android:textColor="@color/label_color"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvRisikokapital"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/result_placeholder"
                                android:textSize="15sp"
                                android:textColor="@color/blue_primary"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:singleLine="true"
                                android:ellipsize="end" />
                        </LinearLayout>

                        <!-- Gebühren (€), max 99,99 -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilGebuehren"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.2"
                            android:layout_marginStart="4dp"
                            android:hint="@string/label_gebuehren"
                            app:endIconMode="none">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etGebuehren"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:digits="0123456789,."
                                android:maxLength="5"
                                android:hint="@string/hint_gebuehren"
                                android:imeOptions="actionDone"
                                android:textColor="@color/on_surface" />
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <!-- Vorgaben-Fehleranzeige -->
                    <TextView
                        android:id="@+id/tvVorgabenFehler"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:textColor="@color/error"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp"
                        android:layout_marginTop="0dp" />

                    <!-- Save button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSpeichern"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_speichern"
                        android:textAllCaps="false"
                        android:textSize="15sp"
                        app:cornerRadius="10dp"
                        style="@style/Widget.Material3.Button.TonalButton" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== CARD 2: Order Angaben ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardEingabe"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/card_margin"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="2dp"
                app:strokeColor="@color/card_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/header_eingabe"
                        android:textSize="@dimen/section_header_size"
                        android:textColor="@color/blue_primary"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true"
                        android:layout_marginBottom="16dp" />

                    <!-- Kaufkurs und Stoploss-Kurs nebeneinander -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <!-- Kaufkurs -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilKaufkurs"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:hint="@string/label_kaufkurs"
                            app:endIconMode="clear_text">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etKaufkurs"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:digits="0123456789,."
                                android:hint="@string/hint_kaufkurs"
                                android:imeOptions="actionNext"
                                android:textColor="@color/on_surface" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- StoppLoss-Kurs -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilStoploss"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:hint="@string/label_stoploss"
                            app:endIconMode="clear_text">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etStoploss"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:digits="0123456789,."
                                android:hint="@string/hint_stoploss"
                                android:imeOptions="actionDone"
                                android:textColor="@color/on_surface" />
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <!-- Calculate button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBerechnen"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_berechnen"
                        android:textAllCaps="false"
                        android:textSize="15sp"
                        app:cornerRadius="10dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== CARD 3: Ergebnis ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardErgebnis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/blue_darker"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/header_ergebnis"
                        android:textSize="@dimen/section_header_size"
                        android:textColor="#99FFFFFF"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true"
                        android:layout_marginBottom="16dp" />

                    <!-- Fehleranzeige (harter Fehler) -->
                    <TextView
                        android:id="@+id/tvFehler"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:textColor="#FF8A65"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />

                    <!-- Zeile 1: Wertpapier-Stücke | Kaufwert -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <!-- Wertpapier-Stücke -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_stuecke"
                                android:textSize="@dimen/result_label_size"
                                android:textColor="#AADDF0" />

                            <TextView
                                android:id="@+id/tvStuecke"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/result_placeholder"
                                android:textSize="@dimen/result_value_size"
                                android:textColor="@color/white"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" />
                        </LinearLayout>

                        <!-- Kaufwert -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_kaufwert"
                                android:textSize="@dimen/result_label_size"
                                android:textColor="#AADDF0" />

                            <TextView
                                android:id="@+id/tvKaufwert"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/result_placeholder"
                                android:textSize="24sp"
                                android:textColor="@color/white"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Warnung: Kaufwert > Vermögen (soft warning, kein Fehler) -->
                    <TextView
                        android:id="@+id/tvWarnKaufwert"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:textColor="#FFD54F"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"
                        android:text="@string/warn_kaufwert_ueber_vermoegen" />

                    <!-- Hinweis: Wertpapier-Stücke = 0 -->
                    <TextView
                        android:id="@+id/tvWarnStueckeNull"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:textColor="#FFD54F"
                        android:textSize="13sp"
                        android:layout_marginBottom="10dp"
                        android:text="@string/warn_stuecke_null" />

                    <!-- Trennlinie -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#33FFFFFF"
                        android:layout_marginBottom="12dp" />

                    <!-- Zeile 2: Maximaler Verlust (volle Breite) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_max_verlust"
                            android:textSize="@dimen/result_label_size"
                            android:textColor="#AADDF0" />

                        <TextView
                            android:id="@+id/tvMaxVerlust"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/result_placeholder"
                            android:textSize="20sp"
                            android:textColor="#FF8A65"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
